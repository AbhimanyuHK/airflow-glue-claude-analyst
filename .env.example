# ═══════════════════════════════════════════════════════════════════
#  Airflow Glue Claude Analyst — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ── Slack ───────────────────────────────────────────────────────────
# Bot User OAuth Token  (Settings → OAuth & Permissions)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-Level Token  (Settings → Basic Information → App-Level Tokens)
# Required scope: connections:write
SLACK_APP_TOKEN=xapp-your-app-token-here


# ── Anthropic Claude ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Model to use. Defaults to claude-sonnet-4-6 if not set.
# CLAUDE_MODEL=claude-sonnet-4-6

# Max tokens for the analysis response (default: 1500)
# CLAUDE_MAX_TOKENS=1500


# ── AWS ─────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# Credentials — omit when running on EC2/ECS with an IAM role attached.
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key


# ── Log fetching ─────────────────────────────────────────────────────
# How far back to search for log events (hours). Default: 2
LOG_LOOKBACK_HOURS=2

# Max characters of log text sent to Claude. Default: 20000
MAX_LOG_CHARS=20000


# ── Airflow / MWAA ───────────────────────────────────────────────────
# CloudWatch log group for your MWAA environment.
# MWAA default: /aws/mwaa/<environment-name>
# Self-hosted: whatever you configured in airflow.cfg
AIRFLOW_LOG_GROUP=/aws/mwaa/airflow


# ── AWS Glue ─────────────────────────────────────────────────────────
# These are the AWS defaults — only change if you customised them.
# GLUE_ERROR_LOG_GROUP=/aws-glue/jobs/error
# GLUE_OUTPUT_LOG_GROUP=/aws-glue/jobs/output
